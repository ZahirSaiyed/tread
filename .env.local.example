# =============================================================
# .env.local.example — TRS Dispatch Platform
# Copy to .env.local and fill in real values
# NEVER commit .env.local to version control
# =============================================================

# =============================================================
# APP
# =============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# =============================================================
# SUPABASE
# =============================================================
NEXT_PUBLIC_SUPABASE_URL=https://placeholder.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxx   # Supabase → Settings → API → Publishable key
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxx   # Supabase → Settings → API → service_role → Reveal

# =============================================================
# TWILIO
# =============================================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=placeholder-auth-token
TWILIO_WEBHOOK_AUTH_TOKEN=placeholder-webhook-auth-token
TWILIO_TRS_NUMBER=+17035550000

# =============================================================
# STRIPE
# =============================================================
STRIPE_SECRET_KEY=sk_test_placeholder
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_PLATFORM_ACCOUNT_ID=acct_placeholder

# =============================================================
# OPENAI
# =============================================================
OPENAI_API_KEY=sk-placeholder
OPENAI_MODEL=gpt-4o-mini
OPENAI_INTENT_CONFIDENCE_THRESHOLD=0.85

# =============================================================
# GOOGLE MAPS
# =============================================================
NEXT_PUBLIC_GOOGLE_MAPS_KEY=placeholder-maps-browser-key
GOOGLE_MAPS_SERVER_KEY=placeholder-maps-server-key

# =============================================================
# SENTRY
# =============================================================
SENTRY_DSN=https://placeholder@sentry.io/placeholder
NEXT_PUBLIC_SENTRY_DSN=https://placeholder@sentry.io/placeholder
SENTRY_AUTH_TOKEN=placeholder-sentry-auth-token
SENTRY_ORG=placeholder-org
SENTRY_PROJECT=trs-platform

# =============================================================
# POSTHOG
# =============================================================
NEXT_PUBLIC_POSTHOG_KEY=phc_placeholder
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# =============================================================
# AUTOMATION
# =============================================================
INTENT_CONFIDENCE_THRESHOLD=0.85
QUOTE_EXPIRY_MINUTES=15
REVIEW_REQUEST_DELAY_SECONDS=0
